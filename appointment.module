<?php

/**
 * @file
 * Primary module hooks for Appointment module.
 */

use Drupal\Core\Render\Element;
use Drupal\Core\Render\Markup;

/**
 * Implements hook_theme().
 */
function appointment_theme(): array
{
  return [
    'appointment_confirmation' => [
      'variables' => [
        'reference'      => NULL,
        'date'           => NULL,
        'time'           => NULL,
        'agency'         => NULL,
        'adviser'        => NULL,
        'customer_name'  => NULL,
        'customer_email' => NULL,
        'customer_phone' => NULL,
      ],
    ],
    'appointment_booking_progress' => [
      'variables' => [
        'steps'        => [],
        'current_step' => 1,
      ],
    ],
    'appointment_email_confirmation' => [
      'template' => 'appointment-email-confirmation',
      'variables' => [
        'reference' => NULL,
        'date' => NULL,
        'time' => NULL,
        'agency' => NULL,
        'adviser' => NULL,
        'customer_name' => NULL,
        'customer_email' => NULL,
        'customer_phone' => NULL,
        'rdv_type' => NULL,
      ],
    ],
    'appointment_email_modification' => [
      'template' => 'appointment-email-modification',
      'variables' => [
        'reference' => NULL,
        'date' => NULL,
        'time' => NULL,
        'agency' => NULL,
        'adviser' => NULL,
        'customer_name' => NULL,
        'customer_email' => NULL,
        'customer_phone' => NULL,
        'rdv_type' => NULL,
      ],
      ],
    'appointment_email_cancellation' => [
      'template' => 'appointment-email-cancellation',
      'variables' => [
        'reference' => NULL,
        'date' => NULL,
        'time' => NULL,
        'agency' => NULL,
        'adviser' => NULL,
        'customer_name' => NULL,
        'customer_email' => NULL,
        'customer_phone' => NULL,
        'rdv_type' => NULL,
      ],
      ],
  ];
}

/**
 * Prepares variables for agency templates.
 *
 * Default template: agency.html.twig.
 *
 * @param array $variables
 *   An associative array containing:
 *   - elements: An associative array containing the agency information and any
 *     fields attached to the entity.
 *   - attributes: HTML attributes for the containing element.
 */
function template_preprocess_agency(array &$variables): void
{
  $variables['view_mode'] = $variables['elements']['#view_mode'];
  foreach (Element::children($variables['elements']) as $key) {
    $variables['content'][$key] = $variables['elements'][$key];
  }
}


/**
 * Prepares variables for appointment templates.
 *
 * Default template: appointment.html.twig.
 *
 * @param array $variables
 *   An associative array containing:
 *   - elements: An associative array containing the appointment information and any
 *     fields attached to the entity.
 *   - attributes: HTML attributes for the containing element.
 */
function template_preprocess_appointment(array &$variables): void
{
  $variables['view_mode'] = $variables['elements']['#view_mode'];
  foreach (Element::children($variables['elements']) as $key) {
    $variables['content'][$key] = $variables['elements'][$key];
  }
}


/**
 * Implements hook_mail().
 *
 * Construit les emails envoyés par EmailService.
 * Appelé automatiquement par MailManager::mail().
 */
function appointment_mail(string $key, array &$message, array $params): void
{
  $message['headers']['Content-Type'] = 'text/html; charset=UTF-8';
  $message['headers']['MIME-Version'] = '1.0';

  $name = $params['customer_name'] ?? '';
  $ref  = $params['reference'] ?? '';
  $date = $params['date_label'] ?? '';
  $time = $params['time_label'] ?? '';
  $ag   = $params['agency_name'] ?? '';
  $adv  = $params['adviser_name'] ?? '';
  $type = $params['rdv_type'] ?? '';

  $renderer = \Drupal::service('renderer');

  switch ($key) {
    case 'confirmation':
      $message['subject'] = "Confirmation de votre rendez-vous {$ref}";
      $build = [
        '#theme' => 'appointment_email_confirmation', // ou modification / cancellation
        // transmettre les variables attendues par la template
        '#reference' => $params['reference'] ?? '',
        '#date' => $params['date_label'] ?? '',
        '#time' => $params['time_label'] ?? '',
        '#agency' => $params['agency_name'] ?? '',
        '#adviser' => $params['adviser_name'] ?? '',
        '#customer_name' => $params['customer_name'] ?? '',
        '#customer_email' => $params['customer_email'] ?? '',
        '#customer_phone' => $params['customer_phone'] ?? '',
        '#rdv_type' => $params['rdv_type'] ?? '',
      ];
      $html = (string) $renderer->renderPlain($build);
      $message['body'][] = Markup::create($html);
      break;

    case 'modification':
      $message['subject'] = "Modification de votre rendez-vous {$ref}";
      $build = [
        '#theme' => 'appointment_email_modification', // ou modification / cancellation
        // transmettre les variables attendues par la template
        '#reference' => $params['reference'] ?? '',
        '#date' => $params['date_label'] ?? '',
        '#time' => $params['time_label'] ?? '',
        '#agency' => $params['agency_name'] ?? '',
        '#adviser' => $params['adviser_name'] ?? '',
        '#customer_name' => $params['customer_name'] ?? '',
        '#customer_email' => $params['customer_email'] ?? '',
        '#customer_phone' => $params['customer_phone'] ?? '',
        '#rdv_type' => $params['rdv_type'] ?? '',
      ];
      $html = (string) $renderer->renderPlain($build);
      $message['body'][] = Markup::create($html);
      break;

    case 'cancellation':
      $message['subject'] = "Annulation de votre rendez-vous {$ref}";
      $build = [
        '#theme' => 'appointment_email_cancellation', // ou modification / cancellation
        // transmettre les variables attendues par la template
        '#reference' => $params['reference'] ?? '',
        '#date' => $params['date_label'] ?? '',
        '#time' => $params['time_label'] ?? '',
        '#agency' => $params['agency_name'] ?? '',
        '#adviser' => $params['adviser_name'] ?? '',
        '#customer_name' => $params['customer_name'] ?? '',
        '#customer_email' => $params['customer_email'] ?? '',
        '#customer_phone' => $params['customer_phone'] ?? '',
        '#rdv_type' => $params['rdv_type'] ?? '',
      ];
      $html = (string) $renderer->renderPlain($build);
      $message['body'][] = Markup::create($html);
      break;
  }
}

/**
 * Implements hook_views_data_alter().
 *
 * Améliore les filtres Views pour les champs entity_reference
 * de l'entité appointment.
 */
function appointment_views_data_alter(array &$data): void
{
  // Filtre Agence → select list des agences disponibles
  if (isset($data['appointment']['agency'])) {
    $data['appointment']['agency']['filter']['id'] = 'in_operator';
    $data['appointment']['agency']['filter']['options callback'] = '_appointment_views_agency_options';
  }

  // Filtre Type → select list des types disponibles
  if (isset($data['appointment']['appointment_type'])) {
    $data['appointment']['appointment_type']['filter']['id'] = 'in_operator';
    $data['appointment']['appointment_type']['filter']['options callback'] = '_appointment_views_type_options';
  }
}

/**
 * Options callback pour le filtre Agence.
 *
 * @return array [agency_id => label]
 */
function _appointment_views_agency_options(): array
{
  $options = ['-- Toutes les agences --'];
  $agencies = \Drupal::entityTypeManager()
    ->getStorage('agency')
    ->loadByProperties(['status' => 1]);
  foreach ($agencies as $agency) {
    $options[$agency->id()] = $agency->label();
  }
  return $options;
}

/**
 * Options callback pour le filtre Type de rendez-vous.
 *
 * @return array [term_id => label]
 */
function _appointment_views_type_options(): array
{
  $options = ['-- Tout --'];
  $terms = \Drupal::entityTypeManager()
    ->getStorage('taxonomy_term')
    ->loadByProperties(['vid' => 'appointment_type', 'status' => 1]);
  foreach ($terms as $term) {
    $options[$term->id()] = $term->label();
  }
  return $options;
}

/**
 * Implements hook_views_data().
 */
function appointment_views_data(): array
{
  $data = [];

  $data['appointment']['appointment_date_formatted'] = [
    'title' => t('Date formatée'),
    'help'  => t('Date du RDV formatée en d/m/Y H:i.'),
    'field' => [
      'id'       => 'appointment_date_formatted',
      'real field' => 'appointment_date',
    ],
  ];

  return $data;
}


